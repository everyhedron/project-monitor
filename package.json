{
  "name": "project-monitor",
  "displayName": "Project Monitor",
  "description": "VS Code dashboard for local project folders and their serving status.",
  "version": "0.0.12",
  "publisher": "everyhedron",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onWebviewPanel:projectMonitor.dashboard",
    "onCommand:projectMonitor.openDashboard",
    "onCommand:projectMonitor.refresh"
  ],
  "main": "./out/extension.js",
  "files": [
    "out/**",
    "LICENSE",
    "README.md",
    "TODO.md"
  ],
  "contributes": {
    "commands": [
      {
        "command": "projectMonitor.openDashboard",
        "title": "Project Monitor: Open Dashboard"
      },
      {
        "command": "projectMonitor.refresh",
        "title": "Project Monitor: Refresh"
      }
    ],
    "configuration": {
      "title": "Project Monitor",
      "properties": {
        "projectMonitor.projects": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Explicit project folder paths tracked on the dashboard. Use the Add Project button in the dashboard, or edit this list directly."
        },
        "projectMonitor.refreshIntervalMs": {
          "type": "number",
          "default": 30000,
          "minimum": 10000,
          "description": "Dashboard auto-refresh interval in milliseconds."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.2.1",
    "typescript": "^5.5.4"
  }
}
