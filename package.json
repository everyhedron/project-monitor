{
  "name": "hedron-project-monitor",
  "displayName": "Hedron Project Monitor",
  "description": "VS Code dashboard for monitoring local project folders, serving status, Git state, TODOs, and extension publishing state.",
  "version": "0.0.2",
  "publisher": "everyhedron",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/everyhedron/project-monitor.git"
  },
  "homepage": "https://github.com/everyhedron/project-monitor#readme",
  "bugs": {
    "url": "https://github.com/everyhedron/project-monitor/issues"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onWebviewPanel:projectMonitor.dashboard"
  ],
  "main": "./out/extension.js",
  "files": [
    "out/**",
    "media/**",
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    "TODO.md"
  ],
  "contributes": {
    "commands": [
      {
        "command": "projectMonitor.openDashboard",
        "title": "Project Monitor: Open Dashboard"
      },
      {
        "command": "projectMonitor.refresh",
        "title": "Project Monitor: Refresh"
      }
    ],
    "configuration": {
      "title": "Project Monitor",
      "properties": {
        "projectMonitor.projects": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Explicit project folder paths tracked on the dashboard. Use the Add Project button in the dashboard, or edit this list directly."
        },
        "projectMonitor.refreshIntervalMs": {
          "type": "number",
          "default": 5000,
          "minimum": 200,
          "description": "Dashboard auto-refresh interval in milliseconds."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.2.1",
    "typescript": "^5.5.4"
  }
}
